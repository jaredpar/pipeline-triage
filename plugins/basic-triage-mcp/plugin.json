{
    "name": "basic-triage-mcp",
    "description": "A simple plugin for testing scenarios",
    "version": "1.0.0",
    "author": {
        "name": "Jared Parsons"
    },
    "mcpServers": {
        "basic-triage-mcp": {
            "command": "dotnet",
            "args": [
                "dnx",
                "basic-triage-mcp",
                "--yes",
                "--source",
